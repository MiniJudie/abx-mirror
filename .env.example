# ─────────────────────────────────────────────────────────────────────────────
# ABX Mirror — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS credentials / targeting ───────────────────────────────────────────────

# AWS CLI profile to use for all deployments (must exist in ~/.aws/config)
AWS_PROFILE=alphmirrors

# AWS region for all resources (DynamoDB, Lambda, S3, API Gateway)
# CloudFront is global but is managed from this region
AWS_REGION=eu-west-3

# ── CloudFormation stack names (optional overrides) ───────────────────────────

# Rename stacks if you run multiple environments (e.g. AbxBackendStack-dev)
BACKEND_STACK_NAME=AbxBackendStack
WATCHER_STACK_NAME=AbxWatcherStack

# ── DynamoDB ──────────────────────────────────────────────────────────────────

# Name of the DynamoDB table that stores indexed loans
DYNAMODB_TABLE_NAME=abx-loans

# DynamoDB table for oracle price history (PK: asset, SK: recordedAt)
PRICES_TABLE_NAME=abx-prices

# ── S3 / CloudFront (frontend hosting) ───────────────────────────────────────

# S3 bucket name for the compiled Next.js static export.
# Defaults to "abx-mirror-frontend-<aws-account-id>" if left blank.
S3_BUCKET_NAME=

# CloudFront distribution ID — filled in automatically after the first
# `pnpm deploy:api`, but you can pin it here to skip the CloudFormation lookup.
CLOUDFRONT_DISTRIBUTION_ID=

# CloudFront default domain (e.g. d1234abcd.cloudfront.net).
# Filled in automatically after deploy; set here to override.
CLOUDFRONT_DOMAIN=

# ── Custom domain (optional) ──────────────────────────────────────────────────

# If you want the frontend served from a custom domain (e.g. abx.example.com),
# set both variables. The ACM certificate must be in us-east-1 (CloudFront
# requirement) and already validated.
CLOUDFRONT_CUSTOM_DOMAIN=
ACM_CERTIFICATE_ARN=

# ── API Gateway ───────────────────────────────────────────────────────────────

# Internal name of the HTTP API Gateway.
API_NAME=abx-loans-api

# Custom domain for the public loans API (e.g. api-abx.example.com).
# Served via CloudFront → API Gateway HTTP API. Uses ACM_CERTIFICATE_ARN (us-east-1).
# Set API_ATTACH_CUSTOM_DOMAIN=true after updating DNS to point at ApiDistributionDomain.
API_CUSTOM_DOMAIN=
API_ATTACH_CUSTOM_DOMAIN=

# CloudFront domain for the API distribution (from deploy:api output).
API_DISTRIBUTION_DOMAIN=

# API endpoint URL — filled in automatically after `pnpm deploy:api`.
# Set manually here to use a pre-existing API or to override for the frontend
# build without re-reading CloudFormation outputs.
NEXT_PUBLIC_API_URL=

# ── Alephium node ────────────────────────────────────────────────────────────

# Alephium full-node URL used by the watcher Lambda to index on-chain loans.
# Use a private/dedicated node for better reliability in production.
ALEPHIUM_NODE_URL=https://node.mainnet.alphscan.io

# ── Matomo analytics ──────────────────────────────────────────────────────────

# Leave both blank to disable analytics entirely (no tracking script is injected).
NEXT_PUBLIC_MATOMO_URL=https://analytics.example.com
NEXT_PUBLIC_MATOMO_SITE_ID=1
